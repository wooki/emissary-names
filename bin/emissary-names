#!/usr/bin/env ruby

require 'optparse'
require_relative '../lib/emissary-names.rb'

# parse command line options
options = {
   culture: 'fantasy',
   number: 10,
   type: 'place'
}
OptionParser.new do | opts |
   opts.banner = "Usage: emissary-names --culture=maritime --number=10 --type=place|family"

   opts.on("-cCULTURE", "--culture=CULTURE", "Culture: desert, arid, mountainous, forested, lowland, maritime, fantasy") do |n|
     options[:culture] = n
   end

   opts.on("-sSEED", "--seed=SEED", "Seed for random generation") do |n|
     options[:seed] = n.to_i
   end

   opts.on("-nNUMBER", "--number=NUMBER", "How many names to generate") do |n|
     options[:number] = n.to_i
   end

   opts.on("-tTYPE", "--type=TYPE", "Name type: place (default) or family") do |n|
     options[:type] = n
   end

end.parse!

seed = options[:seed]
seed = Random.new_seed if !seed
srand seed

ng = Emissary::Names.for_culture(options[:culture])

names = Array.new
options[:number].times do
  names.push(options[:type] == 'family' ? ng.get_family_name : ng.get_name)
end

pp names